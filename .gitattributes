# https://git-scm.com/docs/gitattributes
*	text=auto

*.{cmd,[cC][mM][dD]} text  eol=crlf
*.{bat,[bB][aA][tT]} text  eol=crlf
*.ps1                text  eol=crlf
*.psm1               text  eol=crlf
*.psd1               text  eol=crlf
*.psc1               text  eol=crlf
*.ps1xml             text  eol=crlf
*.clixml             text  eol=crlf

*.sln      text eol=crlf
*.csproj   text eol=crlf
*.vcproj   text eol=crlf
*.vcxproj  text eol=crlf

# bash files
*.bash     text eol=lf
*.fish     text eol=lf
*.sh       text eol=lf
*.zsh      text eol=lf

# cpp files
*.c     text diff=cpp
*.cc    text diff=cpp
*.cxx   text diff=cpp
*.cpp   text diff=cpp
*.c++   text diff=cpp
*.hpp   text diff=cpp
*.h     text diff=cpp
*.h++   text diff=cpp
*.hh    text diff=cpp

# css files
*.css             text diff=css
*.scss            text diff=css

# html files
*.htm             text diff=html
*.html            text diff=html
*.xhtml           text diff=html

# java files
Jenkinsfile     text diff=java
*.java          text diff=java
*.groovy        text diff=java
*.scala         text diff=java
*.gradle        text diff=java

# markdown files
*.md            text diff=markdown

# python files
*.pxd    text diff=python
*.py     text diff=python
*.py3    text diff=python
*.pyw    text diff=python
*.pyx    text diff=python
*.pyz    text diff=python
*.pyi    text diff=python

# rust files
*.rs        text diff=rust
*.toml      text diff=toml
Cargo.lock  text

# Fixes syntax highlighting on GitHub to allow comments
.vscode/*.json linguist-language=JSON-with-Comments

# Exclude from export with 'git archive'
# Exclude githooks from the GitHub language statistics
/.githooks      export-ignore linguist-vendored
/.github        export-ignore
.gitattributes  export-ignore
.gitignore      export-ignore
/.gitmodules    export-ignore
