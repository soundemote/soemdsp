            }
        },
        {
            "name": "linux-gnu-ninja_multi",
            "inherits": "base-ninja_multi",
            "displayName": "GNU",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        }
    ],
